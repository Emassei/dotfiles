#!/bin/sh

# Monitor layout: autorandr handles dock/undock profiles.
# Save a profile from a working layout with:  autorandr --save <name>
# To re-apply on the fly mid-session:         autorandr --change
autorandr --change --default docked 2>/dev/null || true

systemctl --user import-environment DISPLAY XAUTHORITY GTK_USE_PORTAL
dbus-update-activation-environment --systemd DISPLAY XAUTHORITY GTK_USE_PORTAL

setxkbmap -option "caps:swapescape"
xbindkeys -f $HOME/dotfiles/xbindkeys
xrdb -merge $HOME/.Xresources
feh --bg-fill --randomize --no-fehbg ~/media/pictures/wallpaper/* &
flameshot &
dunst &
picom &
# clipmenud disabled — was causing Brave paste freezes (form fields)
# clipmenud &
dwm

