#!/bin/bash
#
# Bootstrap a new Arch machine to match Ernie's working setup.
# Idempotent — safe to re-run.
#
# What this does:
#   1. Installs pacman packages (core OS + dev tools + DWM stack)
#   2. Installs paru (AUR helper) if missing
#   3. Installs AUR packages
#   4. Clones + builds suckless tools (dwm, dwmblocks, dmenu)
#   5. Clones NvChad nvim config
#   6. Sets up tmux TPM
#   7. Initializes git submodules (oh-my-zsh)
#   8. Creates dotfile symlinks
#   9. Installs Google Cloud SDK (official, not AUR)
#  10. Installs system files (NetworkManager dispatcher, reflector config)
#  11. Enables systemd timers (reflector, fstrim, autorandr)
#  12. Sets shell to zsh

set -e

DOTFILES="$HOME/dotfiles"
CODE_DIR="$HOME/code"
SUCKLESS_DIR="$CODE_DIR/suckless"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
info() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

confirm() {
    read -r -p "$1 [y/N] " response
    [[ "$response" =~ ^[Yy]$ ]]
}

# =============================================================================
# Git repositories (your forks of suckless tools + NvChad)
# =============================================================================
declare -A suckless_repos=(
    [dwm]='git@github.com:Emassei/dwm.git'
    [dwmblocks]='git@github.com:Emassei/dwmblocks.git'
    [dmenu]='git@github.com:Emassei/dmenu.git'
)
NVCHAD_REPO='git@github.com:NvChad/starter.git'

# =============================================================================
# Package lists
# =============================================================================
PACKAGES=(
    # Base
    base-devel git pacman-contrib rclone

    # Shell & terminal
    zsh zsh-autosuggestions zsh-syntax-highlighting alacritty tmux

    # Editor
    neovim

    # X11 + DWM stack
    xorg-server xorg-xinit xorg-xrandr xbindkeys picom dunst libnotify
    autorandr feh flameshot

    # Portal (needed for Brave file dialogs)
    xdg-desktop-portal xdg-desktop-portal-gtk

    # Fonts
    noto-fonts ttf-jetbrains-mono-nerd ttf-nerd-fonts-symbols ttf-lekton-nerd

    # File management & TUI
    ranger fzf ripgrep bat tree ncdu

    # Media & PDF
    mpv feh zathura zathura-pdf-poppler

    # Utils
    tldr xclip xsel bc htop jq pwgen lsof rsync

    # Network
    networkmanager network-manager-applet networkmanager-l2tp networkmanager-openvpn
    nm-connection-editor reflector

    # Audio
    pavucontrol pipewire pipewire-pulse pamixer

    # Dev tools
    lazygit lazydocker nodejs-lts-jod npm docker docker-compose docker-buildx
    python-pip pgcli mariadb postgresql-libs

    # Cloud / infra
    aws-cli-v2 azure-cli ansible-core

    # Security / Yubikey
    yubikey-personalization-gui keepassxc pass libfido2

    # Other
    gimp libreoffice-fresh ntfs-3g
)

AUR_PACKAGES=(
    brave-bin
    simple-mtpfs
    pspg
    libxft-bgra
    networkmanager-dmenu-git
    ttf-joypixels
    ranger-git
    yubico-authenticator-bin
    yubikey-manager-qt
    slack-desktop
    aws-session-manager-plugin
    ack
    rofi-greenclip
    oh-my-zsh-git
)

# =============================================================================
# Functions
# =============================================================================
check_arch() {
    if ! command -v pacman &> /dev/null; then
        error "This script is for Arch Linux only."
        exit 1
    fi
}

check_ssh() {
    if ! ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
        error "SSH authentication to GitHub failed."
        error "Set up your SSH keys first, then re-run this script."
        exit 1
    fi
}

refresh_mirrorlist() {
    info "Refreshing pacman mirrorlist with reflector..."
    sudo reflector --country 'United States' --age 6 --latest 20 \
        --protocol https --sort rate --save /etc/pacman.d/mirrorlist
}

install_pacman_packages() {
    info "Installing pacman packages..."
    sudo pacman -Syu --needed --noconfirm "${PACKAGES[@]}"
}

install_paru() {
    if command -v paru &> /dev/null; then
        info "paru already installed"
        return
    fi
    info "Installing paru (AUR helper)..."
    mkdir -p "$CODE_DIR"
    git clone https://aur.archlinux.org/paru.git "$CODE_DIR/paru"
    (cd "$CODE_DIR/paru" && makepkg -si --noconfirm)
}

install_aur_packages() {
    info "Installing AUR packages..."
    paru -S --needed --noconfirm "${AUR_PACKAGES[@]}"
}

setup_directories() {
    info "Creating directory structure..."
    mkdir -p "$CODE_DIR" "$SUCKLESS_DIR"
    mkdir -p "$HOME/.config/zsh"
    mkdir -p "$HOME/.config/alacritty"
    mkdir -p "$HOME/.config/zathura"
    mkdir -p "$HOME/.config/ranger"
    mkdir -p "$HOME/.config/clipmenu"
    mkdir -p "$HOME/.local/share/zsh/history"
    mkdir -p "$HOME/.local/bin"
}

clone_or_pull() {
    local repo=$1 dest=$2
    if [[ -d "$dest/.git" ]]; then
        info "Updating $dest..."
        git -C "$dest" pull --ff-only || warn "$dest pull skipped (dirty/diverged)"
    else
        info "Cloning $repo to $dest..."
        git clone "$repo" "$dest"
    fi
}

setup_tmux() {
    info "Setting up tmux plugin manager..."
    local tpm_dir="$HOME/.tmux/plugins/tpm"
    if [[ ! -d "$tpm_dir" ]]; then
        git clone https://github.com/tmux-plugins/tpm "$tpm_dir"
    else
        info "TPM already installed"
    fi
}

setup_suckless() {
    info "Setting up suckless tools (dwm, dwmblocks, dmenu)..."
    for tool in "${!suckless_repos[@]}"; do
        clone_or_pull "${suckless_repos[$tool]}" "$SUCKLESS_DIR/$tool"
        info "Compiling $tool..."
        (cd "$SUCKLESS_DIR/$tool" && sudo make clean install)
    done
}

setup_nvchad() {
    info "Setting up NvChad..."
    clone_or_pull "$NVCHAD_REPO" "$HOME/.config/nvim"
}

create_symlink() {
    local src=$1 dest=$2
    if [[ -L "$dest" ]]; then
        info "Symlink already exists: $dest"
    elif [[ -e "$dest" ]]; then
        warn "Backing up existing $dest to ${dest}.bak"
        mv "$dest" "${dest}.bak"
        ln -s "$src" "$dest"
        info "Created symlink: $dest -> $src"
    else
        ln -s "$src" "$dest"
        info "Created symlink: $dest -> $src"
    fi
}

setup_symlinks() {
    info "Creating symlinks..."
    create_symlink "$DOTFILES/zsh/zshrc_manager.sh" "$HOME/.config/zsh/.zshrc"
    create_symlink "$DOTFILES/zprofile" "$HOME/.zprofile"
    create_symlink "$DOTFILES/alacritty/alacritty.toml" "$HOME/.config/alacritty/alacritty.toml"
    create_symlink "$DOTFILES/gitconfig/.gitconfig" "$HOME/.gitconfig"
    create_symlink "$DOTFILES/xinitrc_dwm" "$HOME/.xinitrc"
    create_symlink "$DOTFILES/xbindkeys" "$HOME/.xbindkeysrc"
    create_symlink "$DOTFILES/Xresources" "$HOME/.Xresources"
    create_symlink "$DOTFILES/apps/zathura/zathurarc" "$HOME/.config/zathura/zathurarc"
    create_symlink "$DOTFILES/apps/ranger/rc.conf" "$HOME/.config/ranger/rc.conf"
    create_symlink "$DOTFILES/apps/ranger/rifle.conf" "$HOME/.config/ranger/rifle.conf"
    create_symlink "$DOTFILES/apps/ranger/scope.sh" "$HOME/.config/ranger/scope.sh"
    create_symlink "$DOTFILES/apps/ranger/commands.py" "$HOME/.config/ranger/commands.py"
}

setup_zsh() {
    if [[ "$SHELL" != *"zsh"* ]]; then
        info "Changing default shell to zsh..."
        chsh -s "$(which zsh)"
    else
        info "zsh is already the default shell"
    fi
    touch "$HOME/.local/share/zsh/history/.zsh_history"
}

install_gcloud() {
    if [[ -d "$HOME/google-cloud-sdk" ]]; then
        info "gcloud SDK already installed"
        return
    fi
    info "Installing Google Cloud SDK (official, not AUR)..."
    curl -sSL https://sdk.cloud.google.com -o /tmp/gcloud_install.sh
    bash /tmp/gcloud_install.sh --disable-prompts --install-dir="$HOME"
    rm -f /tmp/gcloud_install.sh
}

install_system_files() {
    info "Installing system files..."

    # NetworkManager: turn wifi off when ethernet is connected
    if [[ -f "$DOTFILES/system/NetworkManager-dispatcher/10-wifi-off-on-ethernet" ]]; then
        sudo install -o root -g root -m 755 \
            "$DOTFILES/system/NetworkManager-dispatcher/10-wifi-off-on-ethernet" \
            /etc/NetworkManager/dispatcher.d/10-wifi-off-on-ethernet
    fi

    # Pacman hook: auto-trim cache after every transaction (keep last 2 versions)
    if [[ -f "$DOTFILES/system/pacman-hooks/auto-paccache.hook" ]]; then
        sudo mkdir -p /etc/pacman.d/hooks
        sudo install -o root -g root -m 644 \
            "$DOTFILES/system/pacman-hooks/auto-paccache.hook" \
            /etc/pacman.d/hooks/auto-paccache.hook
    fi

    # systemd user services: rclone gdrive mounts
    if [[ -d "$DOTFILES/system/systemd-user" ]]; then
        mkdir -p "$HOME/.config/systemd/user"
        cp "$DOTFILES/system/systemd-user/"*.service "$HOME/.config/systemd/user/"
        # Ensure mount points exist (services AssertPathIsDirectory)
        mkdir -p "$HOME/gdrive"
        mkdir -p "$HOME/code/python/philosophy/kindle-notes"
    fi

    # Reflector config: keep mirrorlist fresh weekly
    sudo tee /etc/xdg/reflector/reflector.conf > /dev/null <<'EOF'
--save /etc/pacman.d/mirrorlist
--country 'United States'
--age 6
--latest 20
--protocol https
--sort rate
EOF
}

enable_services() {
    info "Enabling systemd timers and services..."

    # Weekly mirrorlist refresh
    sudo systemctl enable --now reflector.timer

    # Weekly SSD TRIM
    sudo systemctl enable --now fstrim.timer

    # Auto-switch monitor profile on plug/unplug
    sudo systemctl enable autorandr.service

    # NetworkManager dispatcher
    sudo systemctl enable --now NetworkManager-dispatcher.service

    # User services
    systemctl --user enable --now greenclip.service

    # rclone mounts: enable only (needs `rclone config` first to set up auth)
    if [[ -f "$HOME/.config/rclone/rclone.conf" ]]; then
        systemctl --user enable --now rclone-gdrive-t490.service rclone-kindle-notes.service 2>/dev/null || \
            warn "rclone services not started — run 'rclone config' first, then enable manually"
    else
        warn "~/.config/rclone/rclone.conf missing — skip rclone services."
        warn "Run 'rclone config' to set up 'gdrive' remote, then:"
        warn "  systemctl --user enable --now rclone-gdrive-t490.service rclone-kindle-notes.service"
    fi

    # Time sync (needed for Yubikey TOTP)
    sudo timedatectl set-ntp true
}

setup_system() {
    info "Configuring system settings..."
    # Arch logo in /etc/issue
    if [[ -f "$DOTFILES/arch_logo" ]]; then
        sudo cp "$DOTFILES/arch_logo" /etc/issue
    fi
}

# =============================================================================
# Main
# =============================================================================
main() {
    echo "========================================"
    echo "  Ernie's Dotfiles Deploy Script"
    echo "========================================"
    echo ""
    echo "This will install and configure:"
    echo "  - pacman + AUR packages (DWM stack, dev tools, fonts)"
    echo "  - Suckless tools (dwm, dwmblocks, dmenu)"
    echo "  - NvChad (neovim config)"
    echo "  - Alacritty, Zsh, tmux configs"
    echo "  - Google Cloud SDK (official installer)"
    echo "  - NetworkManager dispatcher (wifi off on ethernet)"
    echo "  - Systemd timers: reflector (weekly), fstrim (weekly), autorandr"
    echo ""
    echo "After deploy, save autorandr profiles per machine:"
    echo "  - With external monitor:     autorandr --save docked"
    echo "  - On laptop alone:           autorandr --save mobile"
    echo ""

    if ! confirm "Continue?"; then
        echo "Aborted."
        exit 0
    fi

    check_arch
    check_ssh
    refresh_mirrorlist
    setup_directories
    install_pacman_packages
    install_paru
    install_aur_packages
    setup_tmux
    setup_suckless
    setup_nvchad
    setup_symlinks
    install_gcloud
    install_system_files
    enable_services
    setup_zsh
    setup_system

    echo ""
    echo "========================================"
    info "Done. Log out and back in for shell changes."
    info "Then save autorandr profiles (see above)."
    echo "========================================"
}

main "$@"
